# =====================================================================
# Titel:      NPE-Risiko: CompressibleMapData.getBiome() greift auf
#             Minecraft.level statt auf die eigene Welt-Referenz zu
# Schweregrad: Medium
# Kategorie:  Bug
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
#             (Zeilen 49, 154-161)
#
# Problem:
#   getBiome() benutzt fuer den Plains-Fallback
#   MINECRAFT.level.registryAccess(). Die Methode laeuft auf den
#   Worldmap-Worker-Threads (CachedRegion.fillImage ->
#   PersistentMap.getPixelColor -> mapData.getBiome). Minecraft.level
#   ist die live-Referenz des Clients und wird beim Verlassen einer
#   Welt / Dimensionswechsel auf null gesetzt, waehrend Worker-Threads
#   noch Regionen der alten Welt rendern oder speichern koennen ->
#   NullPointerException im Worker, der Region-Refresh bricht ab.
#   Zusaetzlich ist es semantisch falsch, die Registry der (evtl.
#   bereits neuen) aktuellen Welt zu verwenden: Die Klasse haelt mit
#   this.world bereits die Welt, zu der die Daten gehoeren, und
#   getBiomeFromID() benutzt sie korrekt.
#
# Loesung:
#   getBiome() verwendet wie getBiomeFromID() die finale world-Referenz
#   der Instanz. Das ungenutzte MINECRAFT-Feld und der zugehoerige
#   Import entfallen. Ein Null-Check auf MINECRAFT.level mit
#   Fallback-Rueckgabe wurde verworfen, weil damit weiterhin die
#   Registry der falschen Welt verwendet wuerde.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java b/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
@@ -6,7 +6,6 @@
 import com.mamiyaotaru.voxelmap.util.CompressionUtils;
 import java.util.Arrays;
 import java.util.zip.DataFormatException;
-import net.minecraft.client.Minecraft;
 import net.minecraft.client.multiplayer.ClientLevel;
 import net.minecraft.core.registries.Registries;
 import net.minecraft.world.level.biome.Biome;
@@ -45,8 +44,6 @@
     private BiMap<Biome, Integer> biomeToInt;
     int biomeCount = 1;
     private final ClientLevel world;
-
-    private final Minecraft MINECRAFT = Minecraft.getInstance();
 
     public CompressibleMapData(ClientLevel world) {
         this.width = REGION_SIZE;
@@ -155,7 +152,7 @@
     public Biome getBiome(int x, int z) {
         int biomeId = getBiomeId(x, z);
         if (biomeId == 0 && getHeight(x, z) != Short.MIN_VALUE) {
-            return MINECRAFT.level.registryAccess().lookupOrThrow(Registries.BIOME).get(Biomes.PLAINS).get().value();
+            return world.registryAccess().lookupOrThrow(Registries.BIOME).get(Biomes.PLAINS).get().value();
         }
         return this.getBiomeFromID(biomeId);
     }
