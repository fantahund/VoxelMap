# =====================================================================
# Titel:      String-Allokationen im Tick-Pfad: Dimensions-ID wird
#             jeden Tick in Strings umgewandelt und durchsucht
# Schweregrad: Low
# Kategorie:  Performance
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
#             (Zeilen 169-171, 334-336, 556-559)
#
# Problem:
#   calculateCurrentLightAndSkyColor() laeuft ueber onTickInGame()
#   jeden Client-Tick (20x/s). Darin wird fuer den "Ether"-Sonderfall
#   jedes Mal this.world.dimension().identifier().toString()
#   .toLowerCase().contains("ether") ausgewertet: zwei bis drei
#   String-Allokationen plus eine Substring-Suche pro Tick fuer einen
#   Wert, der sich nur beim Welt-/Dimensionswechsel aendern kann.
#   Das ist unnoetiger Allokationsdruck im Tick-/Render-Pfad
#   (GC-Churn), der sich mit den uebrigen Pro-Tick-Allokationen
#   summiert.
#
# Loesung:
#   Das Ergebnis wird beim Weltwechsel einmalig in newWorld()
#   berechnet und im neuen Feld worldIsEther gecached; der Tick-Pfad
#   liest nur noch das boolean. newWorld() ist die einzige Stelle, die
#   this.world zuweist, damit kann der Cache nicht veralten.
#   Die Alternative, die Identifier-Referenz zu vergleichen und nur bei
#   Aenderung neu zu rechnen, wurde verworfen - der explizite Cache am
#   Zuweisungsort ist einfacher und offensichtlich korrekt.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java b/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
@@ -168,6 +168,7 @@
     private boolean lastPaused = true;
     private boolean lastAboveHorizon = true;
     private int lastBiome;
+    private boolean worldIsEther;
 
     // Map Rendering
     private final Matrix4fStack renderMatrixStack = new Matrix4fStack(16);
@@ -333,6 +334,7 @@
 
     public void newWorld(ClientLevel world) {
         this.world = world;
+        this.worldIsEther = world != null && world.dimension().identifier().toString().toLowerCase().contains("ether");
         this.mapData[this.zoom].blank();
         this.doFullRender = true;
         this.calculateCurrentLightAndSkyColor(true);
@@ -554,7 +556,7 @@
                 }
 
                 boolean aboveHorizon = VoxelConstants.getPlayer().getEyePosition(0.0F).y >= this.world.getLevelData().getHorizonHeight(this.world);
-                if (this.world.dimension().identifier().toString().toLowerCase().contains("ether")) {
+                if (this.worldIsEther) {
                     aboveHorizon = true;
                 }
 
