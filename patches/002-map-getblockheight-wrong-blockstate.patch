# =====================================================================
# Titel:      Copy-Paste-Fehler in Map.getBlockHeight(): FluidState des
#             falschen Blocks wird ausgewertet
# Schweregrad: High
# Kategorie:  Bug
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
#             (Zeilen 1303, 1311)
#
# Problem:
#   getBlockHeight() soll die Oberflaechenhoehe einer Nachbarsaeule fuer
#   die Slopemap-Berechnung am Kartenrand ermitteln. Dabei wird die
#   Fluid-Erkennung faelschlich auf den Instanzfeldern
#   this.transparentBlockState bzw. this.surfaceBlockState ausgefuehrt
#   statt auf der lokalen Variable blockState, die den gerade
#   untersuchten Block der Nachbarsaeule enthaelt. Die Instanzfelder
#   enthalten an dieser Stelle Reste der letzten getPixelColor()-
#   Berechnung eines ganz anderen Pixels.
#   Folge: Ist der zufaellig im Feld stehende Block ein Fluid, wird die
#   lokale Variable durch dessen Legacy-Block ersetzt und die
#   Hoehensuche liefert eine falsche Hoehe; ist er keins, wird
#   Waterlogging des tatsaechlich untersuchten Blocks ignoriert.
#   Bemerkbar als fehlerhafte Hangschattierung (Slopemap) an den
#   Kartenraendern der Minimap, abhaengig vom zuletzt berechneten Pixel
#   (nicht deterministisch). Da die Felder auch vom Berechnungsthread
#   beschrieben werden, ist das Verhalten zusaetzlich vom Timing
#   abhaengig.
#
# Loesung:
#   Beide Stellen verwenden nun blockState.getFluidState() - analog zur
#   korrekten Implementierung derselben Logik in getPixelColor() und
#   PersistentMap.getAndStoreData(). Eine Umstellung der Scratch-Felder
#   auf lokale Variablen waere die sauberere Langfrist-Loesung, wurde
#   hier aber verworfen, um den Patch minimal-invasiv zu halten.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java b/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/Map.java
@@ -1300,7 +1300,7 @@
         LevelChunk chunk = (LevelChunk) world.getChunk(blockPos);
         int height = chunk.getHeight(Heightmap.Types.MOTION_BLOCKING, blockPos.getX() & 15, blockPos.getZ() & 15) + 1;
         BlockState blockState = world.getBlockState(blockPos.withXYZ(x, height - 1, z));
-        FluidState fluidState = this.transparentBlockState.getFluidState();
+        FluidState fluidState = blockState.getFluidState();
         if (fluidState != Fluids.EMPTY.defaultFluidState()) {
             blockState = fluidState.createLegacyBlock();
         }
@@ -1308,7 +1308,7 @@
         while (blockState.getLightDampening() == 0 && height > world.getMinY()) {
             --height;
             blockState = world.getBlockState(blockPos.withXYZ(x, height - 1, z));
-            fluidState = this.surfaceBlockState.getFluidState();
+            fluidState = blockState.getFluidState();
             if (fluidState != Fluids.EMPTY.defaultFluidState()) {
                 blockState = fluidState.createLegacyBlock();
             }
