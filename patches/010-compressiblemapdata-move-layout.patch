# =====================================================================
# Titel:      CompressibleMapData.moveX()/moveZ() verschieben Daten im
#             veralteten Interleaved-Layout und wuerden den Datenpuffer
#             korrumpieren
# Schweregrad: Low
# Kategorie:  Bug
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
#             (Zeilen 290-312)
#
# Problem:
#   Seit Datenversion 2 ist der Puffer planar organisiert: LAYERS (22)
#   aufeinanderfolgende Ebenen zu je width*height Bytes (Index:
#   x + z*width + width*height*layer, siehe getData/setData und
#   convertData). moveX() verschiebt aber um x*LAYERS Bytes und moveZ()
#   um z*width*LAYERS Bytes - das ist die Arithmetik des alten
#   Interleaved-Layouts ((x + z*width)*LAYERS + layer), wie es
#   FullMapData noch verwendet. Auf dem planaren Layout wuerde ein
#   Aufruf saemtliche Ebenen ineinanderschieben und die Region
#   irreversibel zerstoeren (inkl. anschliessendem Abspeichern der
#   korrupten Daten). Aktuell wird die Methode fuer Regionen nie
#   aufgerufen (Regionen sind ortsfest), es handelt sich also um eine
#   scharfgestellte Falle fuer kuenftige Aufrufer - die Basisklasse
#   AbstractMapData verlangt die Methoden, und bei FullMapData sind sie
#   der normale Scroll-Pfad.
#
# Loesung:
#   moveX()/moveZ() verschieben nun jede der 22 Ebenen einzeln um
#   x Bytes bzw. z*width Bytes und entsprechen damit exakt der
#   Semantik von FullMapData.moveX/moveZ auf dem planaren Layout.
#   Die Alternative, die Methoden mit UnsupportedOperationException zu
#   versehen, wurde verworfen, weil die Basisklasse die Operation als
#   gueltigen Teil des Vertrags definiert.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java b/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/CompressibleMapData.java
@@ -292,10 +292,16 @@
         if (this.isCompressed) {
             this.decompress();
         }
-        if (x > 0) {
-            System.arraycopy(this.data, x * LAYERS, this.data, 0, this.data.length - x * LAYERS);
-        } else if (x < 0) {
-            System.arraycopy(this.data, 0, this.data, -x * LAYERS, this.data.length + x * LAYERS);
+        // data is stored in planes of width * height bytes per layer (since data
+        // version 2), so each layer plane has to be shifted individually
+        int layerSize = this.width * this.height;
+        for (int layer = 0; layer < LAYERS; ++layer) {
+            int base = layer * layerSize;
+            if (x > 0) {
+                System.arraycopy(this.data, base + x, this.data, base, layerSize - x);
+            } else if (x < 0) {
+                System.arraycopy(this.data, base, this.data, base - x, layerSize + x);
+            }
         }
     }
 
@@ -304,10 +310,14 @@
         if (this.isCompressed) {
             this.decompress();
         }
-        if (z > 0) {
-            System.arraycopy(this.data, z * this.width * LAYERS, this.data, 0, this.data.length - z * this.width * LAYERS);
-        } else if (z < 0) {
-            System.arraycopy(this.data, 0, this.data, -z * this.width * LAYERS, this.data.length + z * this.width * LAYERS);
+        int layerSize = this.width * this.height;
+        for (int layer = 0; layer < LAYERS; ++layer) {
+            int base = layer * layerSize;
+            if (z > 0) {
+                System.arraycopy(this.data, base + z * this.width, this.data, base, layerSize - z * this.width);
+            } else if (z < 0) {
+                System.arraycopy(this.data, base, this.data, base - z * this.width, layerSize + z * this.width);
+            }
         }
     }
 
