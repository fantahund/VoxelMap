# =====================================================================
# Titel:      Native Speicherlecks: Deflater/Inflater werden bei
#             Exceptions nicht freigegeben
# Schweregrad: Medium
# Kategorie:  Resource Leak
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/util/CompressionUtils.java
#             (Zeilen 13-49)
#
# Problem:
#   Deflater und Inflater halten nativen (Off-Heap-)Speicher, der erst
#   durch end() freigegeben wird. In compress()/decompress() steht
#   end() mitten im try-Block: Wirft inflater.inflate() eine
#   DataFormatException (genau der in CompressibleMapData.decompress()
#   und CompressibleMapRegionTexture.decompress() erwartete und
#   abgefangene Fall bei defekten Regionsdateien) oder deflate() eine
#   RuntimeException, wird end() nie aufgerufen. Der Cleaner der JVM
#   gibt den nativen Speicher nur irgendwann bei GC frei; da diese
#   Methoden pro Kartenregion und Kompressionszyklus (alle 5 s pro
#   inaktiver Region) aufgerufen werden, koennen sich bei korrupten
#   Cache-Dateien native Allokationen ansammeln (schleichender
#   RSS-Anstieg, der im Java-Heap nicht sichtbar ist).
#
# Loesung:
#   end() wird in einen finally-Block verschoben, sodass der native
#   Speicher auf jedem Pfad (normal, IOException, DataFormatException)
#   freigegeben wird. setInput/finish wandern in den try-Block, damit
#   auch dortige Fehler abgedeckt sind. try-with-resources direkt auf
#   Deflater/Inflater (AutoCloseable erst in neueren JDKs verfuegbar)
#   wurde zugunsten des expliziten finally verworfen, da end()
#   idempotent ist und das Muster JDK-unabhaengig funktioniert.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/util/CompressionUtils.java b/common/src/main/java/com/mamiyaotaru/voxelmap/util/CompressionUtils.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/util/CompressionUtils.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/util/CompressionUtils.java
@@ -12,39 +12,41 @@
 
     public static byte[] compress(byte[] dataToCompress) {
         Deflater deflater = new Deflater();
-        deflater.setLevel(1);
-        deflater.setInput(dataToCompress);
-        deflater.finish();
         try (ByteArrayOutputStream outputStream = new ByteArrayOutputStream(dataToCompress.length)) {
+            deflater.setLevel(1);
+            deflater.setInput(dataToCompress);
+            deflater.finish();
             byte[] buffer = new byte[1024];
 
             while (!deflater.finished()) {
                 int count = deflater.deflate(buffer);
                 outputStream.write(buffer, 0, count);
             }
-            deflater.end();
 
             return outputStream.toByteArray();
         } catch (IOException e) {
             throw new RuntimeException("IOException should not happen for ByteArrayOutputStream", e);
+        } finally {
+            deflater.end();
         }
     }
 
     public static byte[] decompress(byte[] dataToDecompress) throws DataFormatException {
         Inflater inflater = new Inflater();
-        inflater.setInput(dataToDecompress);
         try (ByteArrayOutputStream outputStream = new ByteArrayOutputStream(dataToDecompress.length)) {
+            inflater.setInput(dataToDecompress);
             byte[] buffer = new byte[1024];
 
             while (!(inflater.finished())) {
                 int count = inflater.inflate(buffer);
                 outputStream.write(buffer, 0, count);
             }
-            inflater.end();
 
             return outputStream.toByteArray();
         } catch (IOException e) {
             throw new RuntimeException("IOException should not happen for ByteArrayOutputStream", e);
+        } finally {
+            inflater.end();
         }
     }
 }
