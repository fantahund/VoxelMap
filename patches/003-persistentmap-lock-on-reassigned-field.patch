# =====================================================================
# Titel:      Synchronisation auf reassigniertem Feld lastRegionsArray
#             bietet keinen gegenseitigen Ausschluss
# Schweregrad: High
# Kategorie:  Race Condition
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/persistent/PersistentMap.java
#             (Zeilen 62, 786-793, 886-890)
#
# Problem:
#   getRegions() (Render-Thread der Weltkarte) und doProcessChunk()
#   (Tick-Pfad) synchronisieren beide auf this.lastRegionsArray.
#   getRegions() ersetzt aber innerhalb des synchronized-Blocks genau
#   dieses Feld durch ein neues Array. Ein Thread, der danach
#   synchronized(this.lastRegionsArray) betritt, lockt ein anderes
#   Objekt als ein Thread, der noch das alte Array haelt - die beiden
#   kritischen Abschnitte schliessen sich nicht mehr gegenseitig aus.
#   Folge: doProcessChunk kann lastLeft/lastRight/lastTop/lastBottom in
#   einem inkonsistenten Zwischenzustand lesen (teilweise aktualisierte
#   Grenzen) und in das falsche Array bzw. an einen falschen Index
#   schreiben. Sichtbar als sporadisch fehlende oder falsch platzierte
#   Regionen auf der Weltkarte; theoretisch auch
#   ArrayIndexOutOfBoundsException, falls das Array zwischen
#   Grenzpruefung und Schreibzugriff schrumpft.
#
# Loesung:
#   Ein dediziertes, finales Lock-Objekt lastRegionsLock schuetzt
#   Grenzen und Array-Referenz konsistent. Die Alternative, das Feld
#   volatile zu machen und Copy-on-Write zu verwenden, wurde verworfen,
#   weil die vier Grenzfelder und das Array zusammen atomar
#   aktualisiert werden muessen.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/PersistentMap.java b/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/PersistentMap.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/PersistentMap.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/persistent/PersistentMap.java
@@ -60,6 +60,7 @@
     int lastTop;
     int lastBottom;
     CachedRegion[] lastRegionsArray = new CachedRegion[0];
+    private final Object lastRegionsLock = new Object();
     final Comparator<CachedRegion> ageThenDistanceSorter = (region1, region2) -> {
         long mostRecentAccess1 = region1.getMostRecentView();
         long mostRecentAccess2 = region2.getMostRecentView();
@@ -783,7 +784,7 @@
             }
 
             this.prunePool();
-            synchronized (this.lastRegionsArray) {
+            synchronized (this.lastRegionsLock) {
                 this.lastLeft = left;
                 this.lastRight = right;
                 this.lastTop = top;
@@ -883,7 +884,7 @@
                         this.cachedRegionsPool.add(cachedRegion);
                     }
 
-                    synchronized (this.lastRegionsArray) {
+                    synchronized (this.lastRegionsLock) {
                         if (regionX >= this.lastLeft && regionX <= this.lastRight && regionZ >= this.lastTop && regionZ <= this.lastBottom) {
                             this.lastRegionsArray[(regionZ - this.lastTop) * (this.lastRight - this.lastLeft + 1) + (regionX - this.lastLeft)] = cachedRegion;
                         }
