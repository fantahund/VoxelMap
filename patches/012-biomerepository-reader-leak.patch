# =====================================================================
# Titel:      Reader-/Stream-Leaks in BiomeRepository.loadBiomeColors()
#             bei IO-Fehlern
# Schweregrad: Low
# Kategorie:  Resource Leak
# Betroffen:  common/src/main/java/com/mamiyaotaru/voxelmap/util/BiomeRepository.java
#             (Zeilen 31-94)
#
# Problem:
#   loadBiomeColors() schliesst den BufferedReader auf die
#   biomecolors.txt des Nutzers und den Ressourcen-InputStream des
#   Mod-Configs nur am Ende des Happy Path. Wirft readLine() oder
#   Integer.decode()-Umfeld eine IOException (oder der Ressourcen-
#   Zugriff schlaegt nach dem Oeffnen fehl), faengt der catch-Block die
#   Exception, aber die Handles bleiben offen. Die Methode laeuft zwar
#   nur beim (Re-)Load der Ressourcen, aber Resource-Reloads (F3+T,
#   Packwechsel) koennen beliebig oft vorkommen, und offene Handles auf
#   die Nutzerdatei blockieren unter Windows das spaetere
#   saveBiomeColors().
#
# Loesung:
#   Beide Leseabschnitte werden auf try-with-resources umgestellt;
#   die expliziten close()-Aufrufe entfallen. Verhalten im Fehlerfall
#   (Loggen und Weiterlaufen) bleibt identisch.
# =====================================================================

diff --git a/common/src/main/java/com/mamiyaotaru/voxelmap/util/BiomeRepository.java b/common/src/main/java/com/mamiyaotaru/voxelmap/util/BiomeRepository.java
--- a/common/src/main/java/com/mamiyaotaru/voxelmap/util/BiomeRepository.java
+++ b/common/src/main/java/com/mamiyaotaru/voxelmap/util/BiomeRepository.java
@@ -32,9 +32,7 @@
